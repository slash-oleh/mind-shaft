# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/

# Translations
*.mo
*.pot

# Logs
logs/
*.log

# Sphinx documentation
docs/_build/

# PyBuilder
target/

#Ipython Notebook
.ipynb_checkpoints

# PyCharm project files
.idea/

# Cython C files
site/

# Exclude .gitkeep
!.gitkeep

# Vendor static files
src/common/vendor/*

# NodeJS dependencies
node_modules/

# AI agent-specific folders.
# For committed instructions use .rulesync folder instead (single source of truth).
# Run `npx rulesync generate --target <agent>` to sync for your favorite agent locally.
.cursor/
.claude/
.agents/

# Documentation copies
docs/rules
docs/skills
docs/stack

# npx skills command artifacts (for personally installed skills)
skills-lock.json

# Temporary
tmp/
