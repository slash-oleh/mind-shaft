{
  "name": "dev-handbook",
  "version": "1.0.0",
  "description": "Development handbook monorepo.",
  "repository": "https://github.com/insolite/dev-rules",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "list": "npm run rules:lint",
    "generate": "npm run rules:generate:ai",
    "rules:lint": "npm run lint -w @dev-handbook/rules",
    "rules:generate:ai": "npm run build:ai -w @dev-handbook/rules && mkdir -p ai/rules && cp -r packages/*/dist/ai/* ai/rules/"
  },
  "type": "module"
}
