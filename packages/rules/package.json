{
  "name": "@dev-handbook/rules",
  "version": "1.0.0",
  "description": "Best practices.",
  "repository": "https://github.com/insolite/dev-rules",
  "type": "module",
  "scripts": {
    "lint": "remark src README.md --no-stdout --quiet",
    "lint:fix": "remark src README.md --no-stdout --quiet -o",
